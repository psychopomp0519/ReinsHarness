#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────
# Reins — AI Agent Harness CLI
# ─────────────────────────────────────────────────────────
set -euo pipefail

REINS_VERSION="0.1.0"
# Resolve symlinks to find the real REINS_HOME
REINS_SELF="${BASH_SOURCE[0]}"
while [[ -L "$REINS_SELF" ]]; do
  REINS_LINK_DIR="$(cd "$(dirname "$REINS_SELF")" && pwd)"
  REINS_SELF="$(readlink "$REINS_SELF")"
  [[ "$REINS_SELF" != /* ]] && REINS_SELF="$REINS_LINK_DIR/$REINS_SELF"
done
REINS_HOME="$(cd "$(dirname "$REINS_SELF")/.." && pwd)"
CLAUDE_DIR="${HOME}/.claude"
REINS_CONFIG_DIR="${HOME}/.reins-config"

# ── Colors ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Help ──
show_help() {
  cat <<'EOF'
Reins — AI Agent Harness

Usage:
  reins                           Start a new session (auto-mode + bypass-permissions)
  reins new <name>                Start a named new session
  reins <name>                    Resume an existing session
  reins list                      List all sessions
  reins fork <name>               Fork current session
  reins --safe [name]             Safe mode (auto-mode only, no bypass-permissions)
  reins --mode <mode> [name]      Start with a specific mode
  reins --pack <pack> new <name>  Start with a pack loaded

  reins setup                     Register skills, agents, hooks with Claude Code
  reins update                    Update Reins (core + packs)
  reins update --core             Update core only
  reins update --check            Check for updates
  reins update --rollback         Rollback to previous version

  reins pack list                 List available packs
  reins pack install <name>       Install a pack (register its skills)
  reins pack install --all        Install all packs
  reins pack remove <name>        Remove a pack
  reins pack create <name>        Create a new pack template

  reins merge <source>            Merge external source
  reins merge list                List merged sources

  reins config set <key> <value>  Set configuration
  reins config get <key>          Get configuration
  reins doctor                    Run environment diagnostics
  reins --version                 Show version
  reins --help                    Show this help

Modes:
  plan · dev · review · discuss · cleanup · security · retro · deploy · bridge
EOF
}

show_version() {
  echo "Reins v${REINS_VERSION}"
}

# ── Ensure dirs ──
ensure_dirs() {
  mkdir -p "$CLAUDE_DIR/skills" "$CLAUDE_DIR/agents" "$REINS_CONFIG_DIR"
}

# ── Skills/Agents registration ──
register_skill() {
  local skill_dir="$1"
  local skill_name="$(basename "$skill_dir")"
  local target="$CLAUDE_DIR/skills/$skill_name"
  [[ -L "$target" ]] && rm "$target"
  [[ -d "$target" ]] || true
  ln -sf "$skill_dir" "$target"
}

register_all_builtin() {
  ensure_dirs
  local count=0

  # Built-in skills
  for skill_dir in "$REINS_HOME"/skills/*/; do
    if [[ -f "${skill_dir}SKILL.md" ]]; then
      register_skill "$skill_dir"
      count=$((count + 1))
    fi
  done

  # Built-in agents
  for agent_file in "$REINS_HOME"/agents/*.md; do
    if [[ -f "$agent_file" ]]; then
      ln -sf "$agent_file" "$CLAUDE_DIR/agents/$(basename "$agent_file")"
    fi
  done

  echo "$count"
}

register_pack_skills() {
  local pack_name="$1"
  local pack_dir="$REINS_HOME/packs/$pack_name"

  if [[ ! -d "$pack_dir" ]]; then
    echo -e "${RED}Pack not found:${NC} $pack_name"
    return 1
  fi

  ensure_dirs
  local count=0

  # Pack skills (flat .md files → wrap in directory)
  if [[ -d "${pack_dir}/skills" ]]; then
    for skill_file in "${pack_dir}/skills/"*.md; do
      if [[ -f "$skill_file" ]]; then
        local sname="$(basename "$skill_file" .md)"
        local target_dir="$CLAUDE_DIR/skills/$sname"
        mkdir -p "$target_dir"
        ln -sf "$skill_file" "$target_dir/SKILL.md"
        count=$((count + 1))
      fi
    done
    # Pack skills (subdirectory with SKILL.md)
    for skill_subdir in "${pack_dir}/skills/"*/; do
      if [[ -f "${skill_subdir}SKILL.md" ]]; then
        register_skill "$skill_subdir"
        count=$((count + 1))
      fi
    done
  fi

  # Pack agents
  if [[ -d "${pack_dir}/agents" ]]; then
    for agent_file in "${pack_dir}/agents/"*.md; do
      if [[ -f "$agent_file" ]]; then
        ln -sf "$agent_file" "$CLAUDE_DIR/agents/$(basename "$agent_file")"
      fi
    done
  fi

  echo "$count"
}

unregister_pack_skills() {
  local pack_name="$1"
  local pack_dir="$REINS_HOME/packs/$pack_name"

  if [[ ! -d "$pack_dir" ]]; then
    echo -e "${RED}Pack not found:${NC} $pack_name"
    return 1
  fi

  local count=0

  if [[ -d "${pack_dir}/skills" ]]; then
    for skill_file in "${pack_dir}/skills/"*.md; do
      if [[ -f "$skill_file" ]]; then
        local sname="$(basename "$skill_file" .md)"
        rm -rf "$CLAUDE_DIR/skills/$sname"
        count=$((count + 1))
      fi
    done
    for skill_subdir in "${pack_dir}/skills/"*/; do
      if [[ -d "$skill_subdir" ]]; then
        local sname="$(basename "$skill_subdir")"
        rm -rf "$CLAUDE_DIR/skills/$sname"
        count=$((count + 1))
      fi
    done
  fi

  if [[ -d "${pack_dir}/agents" ]]; then
    for agent_file in "${pack_dir}/agents/"*.md; do
      if [[ -f "$agent_file" ]]; then
        rm -f "$CLAUDE_DIR/agents/$(basename "$agent_file")"
      fi
    done
  fi

  echo "$count"
}

# ── Hooks injection ──
inject_hooks() {
  local settings_file="$CLAUDE_DIR/settings.json"
  ensure_dirs

  if ! command -v jq &>/dev/null; then
    echo -e "${YELLOW}jq not found — cannot inject hooks${NC}"
    return 1
  fi

  local tmp
  tmp="$(mktemp)"

  if [[ -f "$settings_file" ]]; then
    jq --arg rh "$REINS_HOME" '
      .hooks = {
        "PostToolUse": [
          {
            "matcher": "Write|Edit|MultiEdit",
            "hooks": [
              { "type": "command", "command": ("node " + $rh + "/hooks/dist/auto-format.js") },
              { "type": "command", "command": ("node " + $rh + "/hooks/dist/auto-checkpoint.js") }
            ]
          },
          {
            "matcher": "",
            "hooks": [
              { "type": "command", "command": ("node " + $rh + "/hooks/dist/context-compact.js") }
            ]
          }
        ],
        "PreToolUse": [
          {
            "matcher": "Read",
            "hooks": [
              { "type": "command", "command": ("node " + $rh + "/hooks/dist/security-guard.js") }
            ]
          }
        ],
        "Stop": [
          {
            "matcher": "",
            "hooks": [
              { "type": "command", "command": ("node " + $rh + "/hooks/dist/learning-observer.js") }
            ]
          }
        ]
      } |
      .env.REINS_HOME = $rh
    ' "$settings_file" > "$tmp" && mv "$tmp" "$settings_file"
  else
    cat > "$settings_file" <<SETTINGS
{
  "env": { "REINS_HOME": "$REINS_HOME" },
  "hooks": {
    "PostToolUse": [
      { "matcher": "Write|Edit|MultiEdit", "hooks": [
        { "type": "command", "command": "node $REINS_HOME/hooks/dist/auto-format.js" },
        { "type": "command", "command": "node $REINS_HOME/hooks/dist/auto-checkpoint.js" }
      ]},
      { "matcher": "", "hooks": [
        { "type": "command", "command": "node $REINS_HOME/hooks/dist/context-compact.js" }
      ]}
    ],
    "PreToolUse": [
      { "matcher": "Read", "hooks": [
        { "type": "command", "command": "node $REINS_HOME/hooks/dist/security-guard.js" }
      ]}
    ],
    "Stop": [
      { "matcher": "", "hooks": [
        { "type": "command", "command": "node $REINS_HOME/hooks/dist/learning-observer.js" }
      ]}
    ]
  }
}
SETTINGS
  fi
}

# ── Session helpers ──
session_exists() {
  local name="$1"
  claude session list 2>/dev/null | grep -q "$name" 2>/dev/null
}

build_claude_flags() {
  if [[ "${SAFE_MODE:-false}" == "true" ]]; then
    echo "--enable-auto-mode"
  else
    echo "--dangerously-skip-permissions --enable-auto-mode"
  fi
}

start_new_session() {
  local name="${1:-}"
  local flags
  flags="$(build_claude_flags)"

  if [[ -n "$name" ]]; then
    echo -e "${GREEN}Starting new Reins session:${NC} ${BOLD}$name${NC}"
    # shellcheck disable=SC2086
    claude -n "$name" $flags
  else
    echo -e "${GREEN}Starting new Reins session${NC}"
    # shellcheck disable=SC2086
    claude $flags
  fi
}

resume_session() {
  local name="$1"
  local flags
  flags="$(build_claude_flags)"

  echo -e "${BLUE}Resuming Reins session:${NC} ${BOLD}$name${NC}"
  # shellcheck disable=SC2086
  claude --resume "$name" $flags
}

# ── Subcommands ──
cmd_setup() {
  echo -e "${CYAN}${BOLD}Reins Setup${NC}"
  echo ""

  # 1. Register skills
  echo -e "${BLUE}Registering skills...${NC}"
  local skill_count
  skill_count="$(register_all_builtin)"
  echo -e "  ${GREEN}✓ ${skill_count} built-in skills registered${NC}"

  # 2. Register all pack skills
  local pack_skill_total=0
  for pack_dir in "$REINS_HOME"/packs/*/; do
    if [[ -f "${pack_dir}PACK.yaml" ]]; then
      local pname="$(basename "$pack_dir")"
      local pcount
      pcount="$(register_pack_skills "$pname")"
      pack_skill_total=$((pack_skill_total + pcount))
    fi
  done
  echo -e "  ${GREEN}✓ ${pack_skill_total} pack skills registered${NC}"

  # 3. Inject hooks
  echo -e "${BLUE}Injecting hooks into settings.json...${NC}"
  inject_hooks
  echo -e "  ${GREEN}✓ Hooks configured${NC}"

  echo ""
  echo -e "${GREEN}${BOLD}Setup complete!${NC} Start a session with: ${CYAN}reins new my-project${NC}"
}

cmd_new() {
  local name="${1:?Session name required: reins new <name>}"
  start_new_session "$name"
}

cmd_list() {
  echo -e "${CYAN}Reins Sessions:${NC}"
  claude session list 2>/dev/null || echo "  (no sessions found)"
}

cmd_fork() {
  local name="${1:?Fork name required: reins fork <name>}"
  echo -e "${YELLOW}Forking session as:${NC} ${BOLD}$name${NC}"
  local branch="reins-fork/${name}"
  git checkout -b "$branch" 2>/dev/null && echo -e "${GREEN}Created branch:${NC} $branch"
  start_new_session "$name"
}

cmd_update() {
  local target="${1:-all}"
  case "$target" in
    --core)
      echo -e "${BLUE}Updating Reins core...${NC}"
      cd "$REINS_HOME" && git pull && npm install && npm run build:all
      bash "$REINS_HOME/scripts/register-skills.sh"
      ;;
    --check)
      echo -e "${BLUE}Checking for updates...${NC}"
      cd "$REINS_HOME" && git fetch
      local changes
      changes="$(git log HEAD..origin/main --oneline 2>/dev/null)"
      if [[ -n "$changes" ]]; then
        echo -e "${YELLOW}Updates available:${NC}"
        echo "$changes"
      else
        echo -e "${GREEN}Already up to date.${NC}"
      fi
      ;;
    --rollback)
      echo -e "${YELLOW}Rolling back to previous version...${NC}"
      cd "$REINS_HOME"
      local prev
      prev="$(git rev-parse HEAD~1 2>/dev/null)"
      if [[ -n "$prev" ]]; then
        git checkout "$prev" -- .
        npm install && npm run build:all
        echo -e "${GREEN}Rolled back to:${NC} $prev"
      else
        echo -e "${RED}No previous version to rollback to.${NC}"
      fi
      ;;
    *)
      echo -e "${BLUE}Updating Reins (core + packs)...${NC}"
      cd "$REINS_HOME" && git pull && npm install && npm run build:all
      cmd_setup
      ;;
  esac
}

cmd_pack() {
  local action="${1:?Action required: reins pack <list|install|remove|create>}"
  shift
  case "$action" in
    list)
      echo -e "${CYAN}Available packs:${NC}"
      for pack_dir in "$REINS_HOME"/packs/*/; do
        if [[ -f "${pack_dir}PACK.yaml" ]]; then
          local pname="$(basename "$pack_dir")"
          # Check if installed by checking if any pack skill is linked
          local installed="⬜"
          if [[ -d "${pack_dir}skills" ]]; then
            for sf in "${pack_dir}skills/"*.md; do
              if [[ -f "$sf" ]]; then
                local sn="$(basename "$sf" .md)"
                if [[ -L "$CLAUDE_DIR/skills/$sn/SKILL.md" ]] || [[ -L "$CLAUDE_DIR/skills/$sn" ]]; then
                  installed="${GREEN}✅${NC}"
                  break
                fi
              fi
            done
            # Also check subdirectory skills
            if [[ "$installed" == "⬜" ]]; then
              for sd in "${pack_dir}skills/"*/; do
                if [[ -f "${sd}SKILL.md" ]]; then
                  local sn="$(basename "$sd")"
                  if [[ -L "$CLAUDE_DIR/skills/$sn" ]]; then
                    installed="${GREEN}✅${NC}"
                    break
                  fi
                fi
              done
            fi
          fi
          local desc=""
          desc="$(grep '^description:' "${pack_dir}PACK.yaml" 2>/dev/null | head -1 | sed 's/^description:\s*["]*//;s/["]*$//' | cut -c1-60)"
          echo -e "  ${installed} ${BOLD}${pname}${NC} — ${desc}"
        fi
      done
      ;;
    install)
      if [[ "${1:-}" == "--all" ]]; then
        echo -e "${GREEN}Installing all packs...${NC}"
        local total=0
        for pack_dir in "$REINS_HOME"/packs/*/; do
          if [[ -f "${pack_dir}PACK.yaml" ]]; then
            local pname="$(basename "$pack_dir")"
            local pcount
            pcount="$(register_pack_skills "$pname")"
            echo -e "  ${GREEN}✓${NC} $pname (${pcount} skills)"
            total=$((total + pcount))
          fi
        done
        echo -e "${GREEN}${BOLD}All packs installed:${NC} ${total} skills registered"
      else
        local name="${1:?Pack name required: reins pack install <name>}"
        if [[ ! -d "$REINS_HOME/packs/$name" ]]; then
          echo -e "${RED}Pack not found:${NC} $name"
          echo "Run 'reins pack list' to see available packs."
          exit 1
        fi
        echo -e "${GREEN}Installing pack:${NC} ${BOLD}$name${NC}"
        local count
        count="$(register_pack_skills "$name")"
        echo -e "${GREEN}✓ Installed:${NC} ${count} skills registered from ${name}"
      fi
      ;;
    remove)
      local name="${1:?Pack name required: reins pack remove <name>}"
      echo -e "${RED}Removing pack:${NC} ${BOLD}$name${NC}"
      local count
      count="$(unregister_pack_skills "$name")"
      echo -e "${GREEN}✓ Removed:${NC} ${count} skills unregistered"
      ;;
    create)
      local name="${1:?Pack name required: reins pack create <name>}"
      echo -e "${GREEN}Creating pack template:${NC} ${BOLD}$name${NC}"
      mkdir -p "$REINS_HOME/packs/$name"/{skills,agents}
      cat > "$REINS_HOME/packs/$name/PACK.yaml" <<PACKYAML
name: $name
version: "1.0.0"
description: "Description of $name pack"
author: ""
keywords: []
dependencies: []
skills: []
agents: []
PACKYAML
      echo -e "${GREEN}✓ Pack template created at:${NC} packs/$name/"
      ;;
    *)
      echo -e "${RED}Unknown pack action:${NC} $action"
      echo "Available: list, install, remove, create"
      exit 1
      ;;
  esac
}

cmd_merge() {
  local action="${1:?Source or action required: reins merge <source|list>}"
  shift
  local registry="$REINS_HOME/.reins/merged/registry.json"
  mkdir -p "$(dirname "$registry")"
  [[ -f "$registry" ]] || echo '[]' > "$registry"

  case "$action" in
    list)
      echo -e "${CYAN}Merged sources:${NC}"
      if [[ "$(cat "$registry")" == "[]" ]]; then
        echo "  (none)"
      else
        jq -r '.[] | "  - \(.name) [\(.level)] — \(.source)"' "$registry" 2>/dev/null || echo "  (none)"
      fi
      ;;
    *)
      # Treat as a source path/URL
      echo -e "${BLUE}Analyzing source:${NC} $action"
      if [[ -d "$action" ]]; then
        echo -e "${GREEN}Source is a local directory${NC}"
        echo "  Skills found: $(find "$action" -name 'SKILL.md' 2>/dev/null | wc -l)"
        echo "  Agents found: $(find "$action" -name '*.md' -path '*/agents/*' 2>/dev/null | wc -l)"
        echo ""
        echo "Use: reins merge --level coexist|wrap|convert"
      else
        echo -e "${YELLOW}Remote source — clone first, then merge${NC}"
        echo "  git clone $action /tmp/reins-merge-source"
        echo "  reins merge /tmp/reins-merge-source"
      fi
      ;;
  esac
}

cmd_config() {
  local action="${1:?Action required: reins config <set|get>}"
  shift
  local config_file="$REINS_CONFIG_DIR/config.json"
  mkdir -p "$REINS_CONFIG_DIR"
  [[ -f "$config_file" ]] || echo '{}' > "$config_file"

  case "$action" in
    set)
      local key="${1:?Key required}" value="${2:?Value required}"
      local tmp
      tmp="$(mktemp)"
      jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$config_file" > "$tmp" && mv "$tmp" "$config_file"
      echo -e "${GREEN}✓${NC} $key = $value"
      ;;
    get)
      local key="${1:?Key required}"
      local val
      val="$(jq -r --arg k "$key" '.[$k] // "not set"' "$config_file")"
      echo "$key = $val"
      ;;
    *)
      echo -e "${RED}Unknown config action:${NC} $action"
      exit 1
      ;;
  esac
}

cmd_doctor() {
  echo -e "${CYAN}Reins Environment Diagnostics${NC}"
  echo "────────────────────────────────"

  # Node.js
  if command -v node &>/dev/null; then
    echo -e "  Node.js:     ${GREEN}$(node --version)${NC}"
  else
    echo -e "  Node.js:     ${RED}NOT FOUND${NC}"
  fi

  # Git
  if command -v git &>/dev/null; then
    echo -e "  Git:         ${GREEN}$(git --version | cut -d' ' -f3)${NC}"
  else
    echo -e "  Git:         ${RED}NOT FOUND${NC}"
  fi

  # jq
  if command -v jq &>/dev/null; then
    echo -e "  jq:          ${GREEN}$(jq --version 2>&1)${NC}"
  else
    echo -e "  jq:          ${RED}NOT FOUND${NC}"
  fi

  # Claude Code
  if command -v claude &>/dev/null; then
    echo -e "  Claude Code: ${GREEN}installed${NC}"
  else
    echo -e "  Claude Code: ${RED}NOT FOUND${NC}"
  fi

  # Reins
  echo -e "  Reins:       ${GREEN}v${REINS_VERSION}${NC}"
  echo -e "  Reins Home:  ${BLUE}${REINS_HOME}${NC}"

  # Hooks
  local hook_count
  hook_count=$(find "$REINS_HOME/hooks/dist/" -name "*.js" 2>/dev/null | wc -l)
  if [[ "$hook_count" -gt 0 ]]; then
    echo -e "  Hooks:       ${GREEN}${hook_count} built${NC}"
  else
    echo -e "  Hooks:       ${YELLOW}not built (run: npm run build:hooks)${NC}"
  fi

  # Skills registration
  local skill_count
  skill_count=$(find "$CLAUDE_DIR/skills/" -maxdepth 1 -type l 2>/dev/null | wc -l)
  if [[ "$skill_count" -gt 0 ]]; then
    echo -e "  Skills:      ${GREEN}${skill_count} registered${NC}"
  else
    echo -e "  Skills:      ${YELLOW}not registered (run: reins setup)${NC}"
  fi

  # Hooks in settings.json
  if [[ -f "$CLAUDE_DIR/settings.json" ]] && grep -q "hooks" "$CLAUDE_DIR/settings.json" 2>/dev/null; then
    echo -e "  Settings:    ${GREEN}hooks configured${NC}"
  else
    echo -e "  Settings:    ${YELLOW}hooks not configured (run: reins setup)${NC}"
  fi

  echo "────────────────────────────────"
}

# ── Main ──
SAFE_MODE="false"
START_MODE=""
START_PACK=""

main() {
  if [[ $# -eq 0 ]]; then
    start_new_session
    exit 0
  fi

  case "$1" in
    --help|-h)
      show_help
      exit 0
      ;;
    --version|-v)
      show_version
      exit 0
      ;;
    --safe)
      SAFE_MODE="true"
      shift
      start_new_session "${1:-}"
      exit 0
      ;;
    --mode)
      START_MODE="${2:?Mode name required: reins --mode <mode>}"
      shift 2
      if [[ $# -gt 0 && "$1" == "new" ]]; then
        shift
        start_new_session "${1:-}"
      else
        start_new_session "${1:-}"
      fi
      exit 0
      ;;
    --pack)
      START_PACK="${2:?Pack name required: reins --pack <pack>}"
      shift 2
      # Install the pack first
      register_pack_skills "$START_PACK" > /dev/null 2>&1
      if [[ $# -gt 0 && "$1" == "new" ]]; then
        shift
        start_new_session "${1:-}"
      else
        start_new_session "${1:-}"
      fi
      exit 0
      ;;
    setup)
      cmd_setup
      ;;
    new)
      shift
      cmd_new "${1:-}"
      ;;
    list)
      cmd_list
      ;;
    fork)
      shift
      cmd_fork "${1:-}"
      ;;
    update)
      shift
      cmd_update "${1:---all}"
      ;;
    pack)
      shift
      cmd_pack "$@"
      ;;
    merge)
      shift
      cmd_merge "$@"
      ;;
    config)
      shift
      cmd_config "$@"
      ;;
    doctor)
      cmd_doctor
      ;;
    *)
      local session_name="$1"
      if session_exists "$session_name"; then
        resume_session "$session_name"
      else
        start_new_session "$session_name"
      fi
      ;;
  esac
}

main "$@"
